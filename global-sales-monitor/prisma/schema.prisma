generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Store {
  id     Int     @id @default(autoincrement())
  name   String  @db.VarChar(100) 
  city   String
  lat    Float
  lng    Float
  orders Order[]
}

model Order {
  id        Int      @id @default(autoincrement())
  amount    Float    
  createdAt DateTime @default(now())
  storeId   Int
  store     Store    @relation(fields: [storeId], references: [id])

  @@map("orders") // <-- Este es el truco mágico
}